{
  "text": ":email: A GitHub Action `${{ github.eventName }}` event status is ${{ env.JOB_STATUS }}",
  "attachments": [
    {
      "color": "${{ env.ATTACHMENT_COLOR }}",
      "fields": [
        {
          "title": "Repository",
          "short": false,
          "value": "${{ github.repository }}"
        },
        {
          "title": "Ref",
          "short": false,
          "value": "${{ github.ref }}"
        },
        {
          "title": "Commit",
          "short": false,
          "value": "<${{ github.repositoryUrl }}/commit/${{ github.sha }}>"
        },
        {
          "title": "Author",
          "short": false,
          "value": "${{ github.actor }}"
        },
        {
          "title": "Workflow",
          "short": false,
          "value": "<${{ github.payload.repository.html_url }}/actions/runs/${{ github.runId }}|${{ github.workflow }}>"
        }
      ]
    }
  ]
}
